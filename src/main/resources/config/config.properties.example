# Configuracion de Base de Datos
# Copia este archivo como config.properties y completa tus credenciales locales.

# URL de la base de datos
# Ejemplo: jdbc:mysql://localhost:3306/ocm_nomina
db.url=jdbc:mysql://localhost:3306/ocm_nomina

# Usuario de MySQL
db.user=TU_USUARIO

# Contrasena de MySQL
db.password=TU_CONTRASENA

# Puerto de MySQL
db.port=3306

# Host de MySQL
db.host=localhost
